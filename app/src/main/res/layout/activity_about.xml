<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.game.tetrixa.devimpact.settings.PremiumSettingsBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/aboutPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:background="@drawable/bg_settings_glass_card"
        android:orientation="vertical"
        android:padding="26dp">

        <TextView
            android:id="@+id/aboutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_title"
            android:textAppearance="@style/TextAppearance.Game.Settings.LegalTitle"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/aboutBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/about_studio_body"
            android:textAppearance="@style/TextAppearance.Game.Settings.LegalBody" />

        <TextView
            android:id="@+id/aboutVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textAppearance="@style/TextAppearance.Game.Settings.RowTitle" />

        <TextView
            android:id="@+id/aboutCopyright"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_copyright"
            android:textAppearance="@style/TextAppearance.Game.Settings.RowTitle" />

        <TextView
            android:id="@+id/aboutDeveloper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_developer"
            android:textAppearance="@style/TextAppearance.Game.Settings.RowTitle" />

        <TextView
            android:id="@+id/aboutContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/about_contact_label"
            android:textAppearance="@style/TextAppearance.Game.Settings.RowSummary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aboutCloseButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="22dp"
            android:text="@string/about_close"
            app:backgroundTint="@color/settings_violet"
            app:cornerRadius="22dp"
            android:textColor="@android:color/white" />
    </LinearLayout>
</FrameLayout>
