<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_purchase_success"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="26dp">

    <TextView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:gravity="center"
        android:contentDescription="@string/acc_purchase_success_icon"
        android:text="@string/icon_purchase_success"
        android:textSize="46sp" />

    <TextView
        android:id="@+id/successTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/purchase_success"
        android:textColor="@color/store_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/successMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textColor="@color/store_text_secondary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/successBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_chip_store"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        android:textColor="@color/store_price"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/successButton"
        style="@style/Widget.Game.Store.Button"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="18dp"
        android:text="@string/keep_playing"
        android:textAllCaps="false" />
</LinearLayout>
