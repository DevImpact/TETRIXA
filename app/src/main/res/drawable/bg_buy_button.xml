<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="22dp" />
            <gradient android:angle="0" android:startColor="@color/store_button_end" android:endColor="@color/store_button_start" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="22dp" />
            <gradient android:angle="0" android:startColor="@color/store_button_start" android:endColor="@color/store_button_end" />
            <stroke android:width="1dp" android:color="#FFFFF3A6" />
        </shape>
    </item>
</selector>
