<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#55000000" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="@color/settings_card_background"
                android:centerColor="#F5FFFFFF"
                android:endColor="#FFFFE8A3" />
            <stroke android:width="2dp" android:color="@color/settings_card_stroke" />
            <corners android:radius="30dp" />
            <padding android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp" />
        </shape>
    </item>
</layer-list>
