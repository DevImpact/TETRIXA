<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="0dp" android:right="0dp" android:top="3dp" android:bottom="0dp">
        <shape>
            <corners android:radius="30dp" />
            <solid android:color="#66000000" />
        </shape>
    </item>
    <item android:left="1dp" android:right="1dp" android:top="0dp" android:bottom="3dp">
        <shape>
            <corners android:radius="30dp" />
            <gradient
                android:angle="315"
                android:startColor="@color/store_premium_gold"
                android:centerColor="@color/store_card_glow"
                android:endColor="@color/store_gem_purple" />
        </shape>
    </item>
    <item android:left="5dp" android:right="5dp" android:top="4dp" android:bottom="7dp">
        <shape>
            <corners android:radius="25dp" />
            <gradient
                android:angle="270"
                android:startColor="#FFFFFFFF"
                android:centerColor="@color/store_surface"
                android:endColor="#FFFFE7B0" />
            <stroke android:width="1dp" android:color="#99FFFFFF" />
        </shape>
    </item>
</layer-list>
